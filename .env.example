# ─────────────────────────────────────────────────────────────────────────────
# MoonLight — Environment Variables Reference
# Copy relevant sections to apps/api/.env and apps/web/.env.local
# Never commit real values — this file is a template only
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════════
#  BACKEND  (apps/api/.env)
# ═══════════════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=
NODE_ENV=development       # development | production
ALLOWED_ORIGINS=# comma-separated list of allowed origins
FRONTEND_URL=

# ─── Database ────────────────────────────────────────────────────────────────
# Local:      postgresql://user:password@localhost:5432/dbname
# Production: get from neon.tech → Project → Connection Details → Connection string
DATABASE_URL=

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local:      redis://:password@localhost:6379
# Production: get from upstash.com → Database → Details → Redis URL
REDIS_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=
JWT_REFRESH_EXPIRY=

# ─── Cloudinary (Image Uploads) ──────────────────────────────────────────────
# Get from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Stripe (Payments) ───────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Razorpay (Payments — India) ─────────────────────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Resend (Emails) ─────────────────────────────────────────────────────────
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY=
EMAIL_FROM=

# ─── Groq — AI Shopping Assistant (FREE, no billing) ─────────────────────────
# Get from: console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# ─── Sentry (Error Monitoring) ───────────────────────────────────────────────
# Get from: sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=               # 10% in prod, 1.0 in dev


# ═══════════════════════════════════════════════════════════════════════════
#  FRONTEND  (apps/web/.env.local)
# ═══════════════════════════════════════════════════════════════════════════

# ─── API URL ─────────────────────────────────────────────────────────────────
# Local dev:   http://localhost:4000/api
# Production:  https://moonlight-api-prod.onrender.com/api  ← your Render URL
NEXT_PUBLIC_API_URL=


# ═══════════════════════════════════════════════════════════════════════════
#  CI/CD — GitHub Actions Secrets
#  Add these at: github.com → Repo → Settings → Secrets and Variables → Actions
# ═══════════════════════════════════════════════════════════════════════════

# ─── DEV environment secrets ─────────────────────────────────────────────────
# Get DATABASE_URL from: neon.tech → Project → dev branch → Connection string
DEV_DATABASE_URL=

# Get REDIS_URL from: upstash.com → moonlight-dev database → Redis URL
DEV_REDIS_URL=

DEV_JWT_ACCESS_SECRET=
DEV_JWT_REFRESH_SECRET=
DEV_GROQ_API_KEY=
DEV_SENTRY_DSN=
DEV_FRONTEND_URL=
DEV_ALLOWED_ORIGINS=

# ─── PROD environment secrets ────────────────────────────────────────────────
# Get DATABASE_URL from: neon.tech → Project → main branch → Connection string
PROD_DATABASE_URL=

# Get REDIS_URL from: upstash.com → moonlight-prod database → Redis URL
PROD_REDIS_URL=

PROD_JWT_ACCESS_SECRET=
PROD_JWT_REFRESH_SECRET=
PROD_GROQ_API_KEY=
PROD_SENTRY_DSN=
PROD_FRONTEND_URL=
PROD_ALLOWED_ORIGINS=

# ─── Render Deploy Hooks ─────────────────────────────────────────────────────
# Get from: render.com → Your Service → Settings → Deploy Hooks → Create Hook
RENDER_DEV_DEPLOY_HOOK=
RENDER_PROD_DEPLOY_HOOK=

# ─── Vercel ──────────────────────────────────────────────────────────────────
# Get TOKEN from:      vercel.com → Account Settings → Tokens → Create
# Get ORG_ID from:     vercel.com → Account Settings → General → Your ID
# Get PROJECT_ID from: vercel.com → Project → Settings → General → Project ID
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
